{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Beastmaster Spore",
  "type": "object",
  "required": [
    "id",
    "title",
    "proposal",
    "evidence",
    "lineage",
    "license"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "context": {
      "type": "object"
    },
    "proposal": {
      "type": "object",
      "properties": {
        "spec": {
          "type": [
            "string",
            "object"
          ]
        },
        "dagdiff": {
          "type": "object"
        }
      },
      "required": [
        "dagdiff"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "before": {
            "type": [
              "number",
              "null"
            ]
          },
          "after": {
            "type": [
              "number",
              "null"
            ]
          },
          "status": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "lineage": {
      "type": "object"
    },
    "license": {
      "type": "string"
    }
  }
}