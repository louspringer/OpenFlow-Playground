# Colors and Output Formatting
# This file provides consistent color output across all targets

# Colors for output
RED := \033[0;31m
GREEN := \033[0;32m
YELLOW := \033[0;33m
BLUE := \033[0;34m
PURPLE := \033[0;35m
CYAN := \033[0;36m
NC := \033[0m # No Color

# Export colors
export RED
export GREEN
export YELLOW
export BLUE
export PURPLE
export CYAN
export NC
