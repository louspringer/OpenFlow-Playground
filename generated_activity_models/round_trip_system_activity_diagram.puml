@startuml
!theme plain
skinparam backgroundColor white
skinparam activityFontSize 12
skinparam activityFontName Arial
skinparam activityDiamondBackgroundColor #fff3e0
skinparam activityDiamondBorderColor #f57c00

title Python Module Activity Model

start

:Initialize Module;

:Process Class: RoundTripSystem;

:__init__;
:generate_code_from_extracted_model;
:create_model_from_design;
:save_model;
:load_model;
:generate_code_from_model;
:get_profiling_stats;
:print_profiling_summary;

if (Condition Check?) then (yes)
  :Process Success Path;
else (no)
  :Process Fallback Path;
endif


:Process Standalone Functions;

:__init__;
:generate_code_from_extracted_model;
:create_model_from_design;
:save_model;
:load_model;
:... and 3 more;

:Module Complete;
stop

@enduml