<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:cg="http://example.org/code-generation#"
   xmlns:code="http://example.org/code#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/code-generation#Component">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Component</rdfs:label>
    <rdfs:comment>A code component that can be discovered or generated</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#transformsFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/code-generation#CodeGenerationComponent"/>
    <rdfs:range rdf:resource="http://example.org/reverse-engineering#ReverseEngineeringComponent"/>
    <rdfs:label>transforms from</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code#analyze_file">
    <rdf:type rdf:resource="http://example.org/code#Method"/>
    <cg:hasName>analyze_file</cg:hasName>
    <code:hasReturnType>Dict[str, Any]</code:hasReturnType>
    <code:hasParameter rdf:resource="http://example.org/code#analyze_file_param_0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/reverse-engineering#ReverseEngineeringContext">
    <rdf:type rdf:resource="http://example.org/code-generation#Context"/>
    <rdfs:label>Reverse Engineering Context</rdfs:label>
    <cg:hasFormat rdf:resource="http://example.org/code-generation#ListFormat"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code#generate_fix">
    <rdf:type rdf:resource="http://example.org/code#Method"/>
    <cg:hasName>generate_fix</cg:hasName>
    <code:hasReturnType>str</code:hasReturnType>
    <code:hasParameter rdf:resource="http://example.org/code#generate_fix_param_0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#ASTAnalyzer">
    <rdf:type rdf:resource="http://example.org/code-generation#Component"/>
    <rdf:type rdf:resource="http://example.org/reverse-engineering#ReverseEngineeringComponent"/>
    <cg:hasName>ASTAnalyzer</cg:hasName>
    <cg:hasType>class</cg:hasType>
    <cg:hasDescription>AST-based code analyzer with quality rule integration</cg:hasDescription>
    <cg:hasContext rdf:resource="http://example.org/reverse-engineering#ReverseEngineeringContext"/>
    <cg:hasMethod rdf:resource="http://example.org/code#analyze_file"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code#detect_violations">
    <rdf:type rdf:resource="http://example.org/code#Method"/>
    <cg:hasName>detect_violations</cg:hasName>
    <code:hasReturnType>List[str]</code:hasReturnType>
    <code:hasParameter rdf:resource="http://example.org/code#detect_violations_param_0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#CodeGenerationComponent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/code-generation#Component"/>
    <rdfs:label>Code Generation Component</rdfs:label>
    <rdfs:comment>A component to be generated by the code generation system</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#hasContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/code-generation#Component"/>
    <rdfs:range rdf:resource="http://example.org/code-generation#Context"/>
    <rdfs:label>has context</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code#analyze_file_param_0">
    <rdf:type rdf:resource="http://example.org/code#Parameter"/>
    <cg:hasName>file_path</cg:hasName>
    <cg:hasType>str</cg:hasType>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#DictFormat">
    <rdf:type rdf:resource="http://example.org/code-generation#Format"/>
    <rdfs:label>Dict Format</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#transformsTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/code-generation#QualityRule"/>
    <rdfs:range rdf:resource="http://example.org/code-generation#QualityRule"/>
    <rdfs:label>transformsTo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#hasType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/code-generation#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has type</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#hasMethod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/code-generation#Component"/>
    <rdfs:range rdf:resource="http://example.org/code#Method"/>
    <rdfs:label>has method</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code#Method">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Method</rdfs:label>
    <rdfs:comment>A method within a component</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#QualityRule">
    <rdf:type rdf:resource="http://example.org/code-generation#Component"/>
    <rdf:type rdf:resource="http://example.org/reverse-engineering#ReverseEngineeringComponent"/>
    <cg:hasName>QualityRule</cg:hasName>
    <cg:hasType>class</cg:hasType>
    <cg:hasDescription>Represents a code quality rule with detection and fix strategies</cg:hasDescription>
    <cg:hasContext rdf:resource="http://example.org/reverse-engineering#ReverseEngineeringContext"/>
    <cg:hasMethod rdf:resource="http://example.org/code#detect_violations"/>
    <cg:hasMethod rdf:resource="http://example.org/code#generate_fix"/>
    <cg:transformsTo rdf:resource="http://example.org/code-generation#QualityRule"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#hasName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/code-generation#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has name</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code#hasReturnType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/code#Method"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has return type</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#CodeGenerationContext">
    <rdf:type rdf:resource="http://example.org/code-generation#Context"/>
    <rdfs:label>Code Generation Context</rdfs:label>
    <cg:hasFormat rdf:resource="http://example.org/code-generation#DictFormat"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#hasFormat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/code-generation#Component"/>
    <rdfs:range rdf:resource="http://example.org/code-generation#Format"/>
    <rdfs:label>has format</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code#detect_violations_param_0">
    <rdf:type rdf:resource="http://example.org/code#Parameter"/>
    <cg:hasName>code</cg:hasName>
    <cg:hasType>str</cg:hasType>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#hasDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/code-generation#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>has description</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#ListFormat">
    <rdf:type rdf:resource="http://example.org/code-generation#Format"/>
    <rdfs:label>List Format</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/reverse-engineering#ReverseEngineeringComponent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/code-generation#Component"/>
    <rdfs:label>Reverse Engineering Component</rdfs:label>
    <rdfs:comment>A component discovered during reverse engineering</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/reverse-engineering#transformsTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/reverse-engineering#ReverseEngineeringComponent"/>
    <rdfs:range rdf:resource="http://example.org/code-generation#CodeGenerationComponent"/>
    <rdfs:label>transforms to</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code#generate_fix_param_0">
    <rdf:type rdf:resource="http://example.org/code#Parameter"/>
    <cg:hasName>code</cg:hasName>
    <cg:hasType>str</cg:hasType>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#Context">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Context</rdfs:label>
    <rdfs:comment>The context in which a component exists</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/code-generation#Format">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Format</rdfs:label>
    <rdfs:comment>The data format of a component</rdfs:comment>
  </rdf:Description>
</rdf:RDF>
