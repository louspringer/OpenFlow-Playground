@prefix cg: <http://example.org/code-generation#> .
@prefix code: <http://example.org/code#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix re: <http://example.org/reverse-engineering#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

code:hasReturnType a owl:DatatypeProperty ;
    rdfs:label "has return type" ;
    rdfs:domain code:Method ;
    rdfs:range xsd:string .

cg:ASTAnalyzer a cg:Component,
        re:ReverseEngineeringComponent ;
    cg:hasContext re:ReverseEngineeringContext ;
    cg:hasDescription "AST-based code analyzer with quality rule integration" ;
    cg:hasMethod code:analyze_file ;
    cg:hasName "ASTAnalyzer" ;
    cg:hasType "class" .

cg:CodeGenerationContext a cg:Context ;
    rdfs:label "Code Generation Context" ;
    cg:hasFormat cg:DictFormat .

cg:hasContext a owl:ObjectProperty ;
    rdfs:label "has context" ;
    rdfs:domain cg:Component ;
    rdfs:range cg:Context .

cg:hasDescription a owl:DatatypeProperty ;
    rdfs:label "has description" ;
    rdfs:domain cg:Component ;
    rdfs:range xsd:string .

cg:hasFormat a owl:ObjectProperty ;
    rdfs:label "has format" ;
    rdfs:domain cg:Component ;
    rdfs:range cg:Format .

cg:hasMethod a owl:ObjectProperty ;
    rdfs:label "has method" ;
    rdfs:domain cg:Component ;
    rdfs:range code:Method .

cg:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:domain cg:Component ;
    rdfs:range xsd:string .

cg:hasType a owl:DatatypeProperty ;
    rdfs:label "has type" ;
    rdfs:domain cg:Component ;
    rdfs:range xsd:string .

cg:transformsFrom a owl:ObjectProperty ;
    rdfs:label "transforms from" ;
    rdfs:domain cg:CodeGenerationComponent ;
    rdfs:range re:ReverseEngineeringComponent .

cg:transformsTo a owl:ObjectProperty ;
    rdfs:label "transformsTo" ;
    rdfs:domain cg:QualityRule ;
    rdfs:range cg:QualityRule .

re:transformsTo a owl:ObjectProperty ;
    rdfs:label "transforms to" ;
    rdfs:domain re:ReverseEngineeringComponent ;
    rdfs:range cg:CodeGenerationComponent .

code:analyze_file a code:Method ;
    code:hasParameter code:analyze_file_param_0 ;
    code:hasReturnType "Dict[str, Any]" ;
    cg:hasName "analyze_file" .

code:analyze_file_param_0 a code:Parameter ;
    cg:hasName "file_path" ;
    cg:hasType "str" .

code:detect_violations a code:Method ;
    code:hasParameter code:detect_violations_param_0 ;
    code:hasReturnType "List[str]" ;
    cg:hasName "detect_violations" .

code:detect_violations_param_0 a code:Parameter ;
    cg:hasName "code" ;
    cg:hasType "str" .

code:generate_fix a code:Method ;
    code:hasParameter code:generate_fix_param_0 ;
    code:hasReturnType "str" ;
    cg:hasName "generate_fix" .

code:generate_fix_param_0 a code:Parameter ;
    cg:hasName "code" ;
    cg:hasType "str" .

cg:DictFormat a cg:Format ;
    rdfs:label "Dict Format" .

cg:ListFormat a cg:Format ;
    rdfs:label "List Format" .

cg:CodeGenerationComponent a owl:Class ;
    rdfs:label "Code Generation Component" ;
    rdfs:comment "A component to be generated by the code generation system" ;
    rdfs:subClassOf cg:Component .

re:ReverseEngineeringContext a cg:Context ;
    rdfs:label "Reverse Engineering Context" ;
    cg:hasFormat cg:ListFormat .

cg:Context a owl:Class ;
    rdfs:label "Context" ;
    rdfs:comment "The context in which a component exists" .

cg:Format a owl:Class ;
    rdfs:label "Format" ;
    rdfs:comment "The data format of a component" .

cg:QualityRule a cg:Component,
        re:ReverseEngineeringComponent ;
    cg:hasContext re:ReverseEngineeringContext ;
    cg:hasDescription "Represents a code quality rule with detection and fix strategies" ;
    cg:hasMethod code:detect_violations,
        code:generate_fix ;
    cg:hasName "QualityRule" ;
    cg:hasType "class" ;
    cg:transformsTo cg:QualityRule .

re:ReverseEngineeringComponent a owl:Class ;
    rdfs:label "Reverse Engineering Component" ;
    rdfs:comment "A component discovered during reverse engineering" ;
    rdfs:subClassOf cg:Component .

code:Method a owl:Class ;
    rdfs:label "Method" ;
    rdfs:comment "A method within a component" .

cg:Component a owl:Class ;
    rdfs:label "Component" ;
    rdfs:comment "A code component that can be discovered or generated" .

