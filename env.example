# Neo4j Database Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env files with real credentials

NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_actual_password_here

# GitGuardian API Configuration
# Get your API token from: https://dashboard.gitguardian.com/workspace/settings/api
GITGUARDIAN_API_TOKEN=your_gitguardian_api_token_here

# Security Note:
# - Store real credentials in 1Password or secure credential manager
# - Use environment variables for all sensitive configuration
# - Never hardcode credentials in source code
# - This file is for documentation only
