{
  "models": {
    "project": {
      "implementation": "project_model_manager",
      "config": {
        "model_file": "project_model_registry.json",
        "backup_dir": "backups"
      }
    },
    "registry_manager": {
      "implementation": "json_model_manager",
      "config": {
        "model_file": "model_registry.json",
        "backup_dir": "backups"
      }
    },
    "neo4j_data": {
      "implementation": "neo4j_model_manager",
      "config": {
        "uri": "bolt://localhost:7687",
        "username": "neo4j",
        "password": "secret",
        "database": "neo4j"
      }
    },
    "test_data": {
      "implementation": "json_model_manager",
      "config": {
        "model_file": "test_data.json",
        "backup_dir": "backups"
      }
    },
    "neo4j_secure": {
      "implementation": "neo4j_model_manager",
      "config": {
        "uri": "bolt://localhost:7687",
        "username": "neo4j",
        "password": "${NEO4J_PASSWORD}",
        "database": "neo4j"
      }
    }
  }
}