# 🚀 TiDB AgentX Hackathon - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# TiDB Serverless Configuration
# =============================================================================
# Your TiDB Serverless connection details
TIDB_HOST=your-tidb-serverless-host.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your-tidb-username
TIDB_PASSWORD=your-tidb-password
TIDB_DATABASE=hackathon_2025
TIDB_SSL_MODE=require

# =============================================================================
# OpenFlow Tools Configuration
# =============================================================================
# Path to main OpenFlow Playground project
OPENFLOW_ROOT=../..
OPENFLOW_TOOLS_MODE=development
OPENFLOW_UPDATE_FREQUENCY=realtime

# Ghostbusters Configuration
GHOSTBUSTERS_ENABLED=true
GHOSTBUSTERS_MODE=development
GHOSTBUSTERS_LOG_LEVEL=INFO
GHOSTBUSTERS_SCAN_INTERVAL=300

# Code Quality Configuration
CODE_QUALITY_ENABLED=true
CODE_QUALITY_MODE=development
CODE_QUALITY_AUTOFIX=true
CODE_QUALITY_REPORT_FORMAT=html

# Security Configuration
SECURITY_SCAN_ENABLED=true
SECURITY_SCAN_MODE=development
SECURITY_SCAN_DEPTH=comprehensive
SECURITY_SCAN_REPORT_FORMAT=json

# MDC Generator Configuration
MDC_GENERATOR_ENABLED=true
MDC_GENERATOR_MODE=development
MDC_GENERATOR_OUTPUT_FORMAT=markdown

# =============================================================================
# AI and Machine Learning Configuration
# =============================================================================
# OpenAI Configuration (for AI agents)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# Vector Search Configuration
VECTOR_SEARCH_ENABLED=true
VECTOR_SEARCH_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_SEARCH_DIMENSION=384
VECTOR_SEARCH_SIMILARITY_METRIC=cosine

# AI Agent Configuration
AI_AGENTS_COUNT=5
AI_AGENTS_TYPES=tester,validator,optimizer,security,documentation
AI_AGENTS_MAX_CONCURRENT=3
AI_AGENTS_TIMEOUT=300

# =============================================================================
# Development Environment Configuration
# =============================================================================
# Environment type
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# Application Configuration
APP_NAME=TiDB AgentX Hackathon
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8501
APP_RELOAD=true

# Database Configuration
DATABASE_URL=mysql+pymysql://${TIDB_USER}:${TIDB_PASSWORD}@${TIDB_HOST}:${TIDB_PORT}/${TIDB_DATABASE}
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# Storage Configuration
# =============================================================================
# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=hackathon-storage
MINIO_SECURE=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# PostgreSQL Configuration (for metadata)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hackathon_meta
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon123
POSTGRES_SSL=false

# =============================================================================
# Monitoring and Observability
# =============================================================================
# Prometheus Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics

# Grafana Configuration
GRAFANA_ENABLED=true
GRAFANA_HOST=localhost
GRAFANA_PORT=3000
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

# Logging Configuration
LOG_TO_FILE=true
LOG_FILE_PATH=logs/tidb-hackathon.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# =============================================================================
# Testing Configuration
# =============================================================================
# Test Environment
TEST_ENVIRONMENT=docker
TEST_DATABASE_URL=mysql+pymysql://test_user:test_pass@localhost:4000/test_db
TEST_COVERAGE_ENABLED=true
TEST_COVERAGE_THRESHOLD=80
TEST_TIMEOUT=300

# =============================================================================
# CI/CD Configuration
# =============================================================================
# GitHub Configuration
GITHUB_TOKEN=your-github-token
GITHUB_REPOSITORY=openflow-playground/tidb-agentx-hackathon
GITHUB_BRANCH=main

# Docker Configuration
DOCKER_REGISTRY=your-registry.com
DOCKER_IMAGE_NAME=tidb-hackathon
DOCKER_IMAGE_TAG=latest

# =============================================================================
# Security Configuration
# =============================================================================
# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
CORS_ORIGINS=http://localhost:8501,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable specific features
FEATURE_VECTOR_SEARCH=true
FEATURE_AI_AGENTS=true
FEATURE_MULTI_AGENT_TESTING=true
FEATURE_AUTOMATED_QUALITY=true
FEATURE_SECURITY_SCANNING=true
FEATURE_DOCUMENTATION_GENERATION=true
FEATURE_MONITORING_DASHBOARDS=true
FEATURE_JUPYTER_INTEGRATION=true

# =============================================================================
# Development Tools Configuration
# =============================================================================
# Jupyter Configuration
JUPYTER_ENABLED=true
JUPYTER_HOST=0.0.0.0
JUPYTER_PORT=8888
JUPYTER_TOKEN=hackathon2025
JUPYTER_ALLOW_ROOT=true

# Pre-commit Configuration
PRE_COMMIT_ENABLED=true
PRE_COMMIT_AUTO_UPDATE=true
PRE_COMMIT_INSTALL_HOOKS=true

# Code Quality Tools
BLACK_ENABLED=true
FLAKE8_ENABLED=true
MYPY_ENABLED=true
ISORT_ENABLED=true
BANDIT_ENABLED=true
SAFETY_ENABLED=true

# =============================================================================
# Performance Configuration
# =============================================================================
# Worker Configuration
WORKER_PROCESSES=4
WORKER_THREADS=2
WORKER_MAX_REQUESTS=1000
WORKER_TIMEOUT=30

# Cache Configuration
CACHE_ENABLED=true
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=tidb_hackathon

# =============================================================================
# External Services Configuration
# =============================================================================
# 1Password Integration
ONEPASSWORD_ENABLED=true
ONEPASSWORD_ITEM_ID=your-1password-item-id
ONEPASSWORD_VAULT_ID=your-1password-vault-id

# Slack Integration (for notifications)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_CHANNEL=#hackathon

# Email Configuration
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# =============================================================================
# Backup and Recovery Configuration
# =============================================================================
# Backup Configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=./backups

# Recovery Configuration
RECOVERY_ENABLED=true
RECOVERY_AUTO_RESTORE=false
RECOVERY_VERIFICATION=true

# =============================================================================
# Documentation
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control
# Use env.example as a template for team members







